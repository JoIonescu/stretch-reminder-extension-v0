{
  "manifest_version": 3,
  "name": "Stretch Break Reminder",
  "description": "Reminds you to stand up and stretch while working.",
  "version": "1.0",

  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "idle"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "icons": {
    "128": "icon.png"
  }
}